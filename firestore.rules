rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function userExists() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Users collection - users can create own doc, read own, no updates
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false; // Admins only via Firebase Console
    }

    // Events collection - role-based access
    match /events/{eventId} {
      allow read: if userExists() && getUser().role in ["viewer", "editor", "admin"];
      allow write: if userExists() && getUser().role in ["editor", "admin"];
    }

    // Event content collection - role-based access
    match /eventContents/{contentId} {
      allow read: if userExists() && getUser().role in ["viewer", "editor", "admin"];
      allow write: if userExists() && getUser().role in ["editor", "admin"];
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}